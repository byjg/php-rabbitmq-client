{
  "name": "byjg/rabbitmq-client",
  "description": "It creates a simple abstraction layer to publish and consume messages from the RabbitMQ Server using the component byjg/message-queue-client.",
  "autoload": {
    "psr-4": {
      "ByJG\\MessageQueueClient\\RabbitMQ\\": "src/"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "require": {
    "php": ">=8.3 <8.6",
    "ext-curl": "*",
    "byjg/message-queue-client": "^6.0",
    "php-amqplib/php-amqplib": "^3.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.5",
    "vimeo/psalm": "^5.9|^6.13"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "psalm": "vendor/bin/psalm --threads=1"
  },
  "license": "MIT"
}
